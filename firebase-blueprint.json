{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "timestamp" }
      },
      "required": ["email", "role"]
    },
    "Profile": {
      "title": "Profile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" }
      }
    },
    "StakingPosition": {
      "title": "StakingPosition",
      "description": "User's staking position",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["userId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Store users"
    },
    "/profiles/{userId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "Store profiles"
    },
    "/staking/{documentId}": {
      "schema": { "$ref": "#/entities/StakingPosition" },
      "description": "Store staking"
    }
  }
}
